#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

AIRLOCK_BIN_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
AIRLOCK_LIBEXEC_DIR="${AIRLOCK_LIBEXEC_DIR:-$(cd -- "${AIRLOCK_BIN_DIR}/../libexec" && pwd -P)}"
AIRLOCK_BIN="${AIRLOCK_BIN_DIR}/airlock"
export AIRLOCK_LIBEXEC_DIR

# shellcheck source=/dev/null
source "${AIRLOCK_LIBEXEC_DIR}/airlock/refuse_root.sh"
airlock_refuse_root

# shellcheck source=/dev/null
source "${AIRLOCK_LIBEXEC_DIR}/airlock/common.sh"

# shellcheck source=/dev/null
source "${AIRLOCK_LIBEXEC_DIR}/airlock/cli-utils.sh"

: "${AIRLOCK_FIREFOX_USE_SEPARATE_PROFILE:=true}"
: "${AIRLOCK_FIREFOX_PROFILE_DIR:=}"

# Internal flags
AIRLOCK_FIREFOX_TEMP_PROFILE='false'
AIRLOCK_FIREFOX_CLEAN_PROFILE='false'

usage() {
  cat <<'EOF'
Usage:
  airlock-firefox (--profile NAME | --config PATH) [options] [--] [URL ...] [FIREFOX_ARGS...]

Options:
  --separate-profile        Use a dedicated Firefox profile (default)
  --no-separate-profile     Reuse Firefox's default profile
  --profile-dir DIR         Explicit profile directory (only used with --separate-profile)
  --temp-profile            Create a temporary profile dir and delete it after Firefox exits
  --clean-profile           Delete the configured profile dir and exit (refuses if profile appears in use)
  -h, --help                Show this help

Notes:
  - If you want to pass Firefox flags starting with '-', put them after '--'.
EOF
}

airlock_cli_usage() { usage; }

# Expand a leading "~" in a path (bash-only, no external deps)
_expand_tilde() {
  local p="$1"
  if [[ "$p" == "~" ]]; then
    printf '%s\n' "$HOME"
  elif [[ "$p" == "~/"* ]]; then
    printf '%s\n' "${HOME}${p:1}"
  else
    printf '%s\n' "$p"
  fi
}

