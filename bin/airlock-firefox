_firefox_default_profile_dir() {
  printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}/airlock/firefox-${AIRLOCK_CONFIG_NAME}"
}

_firefox_apply_defaults() {
  if [[ "$AIRLOCK_FIREFOX_USE_SEPARATE_PROFILE" == 'true' && -z "$AIRLOCK_FIREFOX_PROFILE_DIR" ]]; then
    AIRLOCK_FIREFOX_PROFILE_DIR="$(_firefox_default_profile_dir)"
  fi
  if [[ -n "$AIRLOCK_FIREFOX_PROFILE_DIR" ]]; then
    AIRLOCK_FIREFOX_PROFILE_DIR="$(_expand_tilde "$AIRLOCK_FIREFOX_PROFILE_DIR")"
  fi
  airlock_log "Using Firefox profile directory: $AIRLOCK_FIREFOX_PROFILE_DIR"
}

